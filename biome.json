{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "extends": ["./packages/config/biome.json"],
  "files": {
    "includes": [
      "**/*",
      "!**/*.astro",
      "!**/node_modules",
      "!**/dist",
      "!**/.turbo",
      "!**/.astro",
      "!**/.git",
      "!**/*.gen.ts",
      "!apps/admin/src/routeTree.gen.ts",
      "!**/*.css"
    ]
  },
  "overrides": [
    {
      "includes": [
        "apps/admin/src/components/PostEditor.tsx",
        "apps/web/src/components/islands/ProjectsIsland.tsx",
        "apps/web/src/components/islands/ExperienceIsland.tsx"
      ],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    }
  ]
}
