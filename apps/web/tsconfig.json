{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["astro/tsconfigs/strict", "@jcsoftdev/config/tsconfig.base.json"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true
  },
  "include": ["src/**/*", "astro.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
