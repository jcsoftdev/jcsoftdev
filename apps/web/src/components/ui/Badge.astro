---
type Variant = "solid" | "ghost" | "accent";
type Size = "sm" | "md";

interface Props {
  variant?: Variant;
  size?: Size;
  class?: string;
}

const {
  variant = "solid",
  size = "md",
  class: className,
  ...rest
} = Astro.props;

const variantStyles: Record<Variant, string> = {
  solid: `background: var(--color-surface-elevated); color: var(--color-text-secondary); border: 1px solid var(--color-border);`,
  ghost: `background: transparent; color: var(--color-text-secondary); border: 1px solid var(--color-border);`,
  accent: `background: var(--color-accent-soft); color: var(--color-accent); border: 1px solid var(--color-accent-muted);`,
};

const sizeStyles: Record<Size, string> = {
  sm: `font-size: var(--text-xs); padding: 0.15rem 0.5rem;`,
  md: `font-size: var(--text-sm); padding: 0.25rem 0.75rem;`,
};
---

<span
  class:list={[`badge`, `badge-${variant}`, `badge-${size}`, className]}
  style={`display: inline-flex; align-items: center; border-radius: var(--radius-full); font-family: var(--font-mono); font-weight: 500; ${variantStyles[variant]} ${sizeStyles[size]}`}
  {...rest}
>
  <slot />
</span>
