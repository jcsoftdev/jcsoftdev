---
interface Props {
  accent?: boolean;
  class?: string;
}

const { accent = false, class: className }: Props = Astro.props;
---

<span
  class:list={["mono", { "mono-accent": accent }, className]}
  style={`font-family: var(--font-mono); letter-spacing: var(--tracking-mono);${accent ? " color: var(--color-accent);" : ""}`}
>
  <slot />
</span>
