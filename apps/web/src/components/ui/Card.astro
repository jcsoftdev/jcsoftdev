---
interface Props {
  hover?: boolean;
  class?: string;
}

const { hover = false, class: className }: Props = Astro.props;
---

<div
  class:list={[`card`, { "card-hover": hover }, className]}
  style={`background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--spacing-6); transition: transform var(--duration-base) var(--ease-out-expo), box-shadow var(--duration-base) var(--ease-out-expo), border-color var(--duration-base) var(--ease-out-expo);`}
  data-hover={hover ? "true" : undefined}
>
  <slot />
</div>

<style>
  .card-hover:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-accent);
    border-color: var(--color-accent-muted);
  }
</style>
