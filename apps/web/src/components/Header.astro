---
import { isActive } from "../lib/active-link";
import HeaderScrollState from "./islands/ui/HeaderScrollState";

const path = Astro.url.pathname;

const navLinks = [
  { label: "Work", href: "/#work" },
  { label: "Experience", href: "/#experience" },
  { label: "About", href: "/#about" },
  { label: "Writing", href: "/blog" },
] as const;
---

<!-- 1px sentinel: HeaderScrollState observes this to detect scroll-past-header -->
<div
  id="header-sentinel"
  aria-hidden="true"
  style="position: absolute; top: 16px; height: 1px; width: 1px; pointer-events: none;"
>
</div>

<!-- Side-effect island: sets data-scrolled on <header> via IntersectionObserver -->
<HeaderScrollState client:load />

<header
  data-scrolled="false"
  class="sticky top-0 z-[var(--z-header)] flex items-center justify-between gap-3 border-b border-transparent px-4 sm:px-[var(--container-px)] py-3 sm:py-4 transition-[backdrop-filter,background-color,border-color] duration-[var(--duration-base)] data-[scrolled=true]:border-b data-[scrolled=true]:border-[color:var(--color-border-soft)] data-[scrolled=true]:bg-[color:var(--backdrop-bg)] data-[scrolled=true]:backdrop-blur-xl"
>
  <!-- Brand with violet dot — secondary line hidden on mobile -->
  <a
    href="/"
    aria-label="jcsoftdev — home"
    class="group flex items-center gap-2 font-mono text-sm tracking-[var(--tracking-mono)] text-[color:var(--color-text-primary)] outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-background)] rounded-sm shrink-0"
  >
    <span
      aria-hidden="true"
      class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent)] transition-[box-shadow] duration-[var(--duration-base)] group-hover:shadow-[0_0_8px_var(--color-accent)]"
    ></span>
    <span>jcsoftdev</span>
    <span
      class="text-[color:var(--color-text-muted)] hidden sm:inline"
      aria-hidden="true">/</span
    >
    <span class="text-[color:var(--color-text-secondary)] hidden sm:inline"
      >jc valencia</span
    >
  </a>

  <!-- Mobile menu toggle (hidden md+) -->
  <button
    type="button"
    aria-label="Open menu"
    aria-controls="mobile-nav"
    aria-expanded="false"
    data-mobile-toggle
    class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-md border border-[color:var(--color-border-soft)] text-[color:var(--color-text-secondary)] transition-colors active:scale-[0.95] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:outline-none"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      aria-hidden="true"
    >
      <path data-menu-open d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"
      ></path>
      <path
        data-menu-close
        d="M6 6l12 12M6 18L18 6"
        class="hidden"
        stroke-linecap="round"></path>
    </svg>
  </button>

  <!-- Desktop navigation + contact CTA -->
  <nav aria-label="Main navigation" class="hidden md:flex items-center gap-8">
    <ul class="flex items-center gap-7">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(path, href) ? "page" : undefined}
              class="relative font-mono text-sm text-[color:var(--color-text-secondary)] outline-none transition-colors duration-[var(--duration-fast)] hover:text-[color:var(--color-text-primary)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-background)] rounded-sm aria-[current=page]:text-[color:var(--color-text-primary)] aria-[current=page]:before:absolute aria-[current=page]:before:-left-3 aria-[current=page]:before:top-1/2 aria-[current=page]:before:-translate-y-1/2 aria-[current=page]:before:h-1 aria-[current=page]:before:w-1 aria-[current=page]:before:rounded-full aria-[current=page]:before:bg-[color:var(--color-accent)] aria-[current=page]:before:[box-shadow:0_0_6px_var(--color-accent)]"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="mailto:hello@jcsoftdev.com"
      class="inline-flex items-center gap-2 font-mono text-xs text-[color:var(--color-text-secondary)] outline-none transition-colors duration-[var(--duration-fast)] hover:text-[color:var(--color-accent)] focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[color:var(--color-background)] rounded-sm"
    >
      <span aria-hidden="true">→</span>
      Say hi
    </a>
  </nav>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-nav"
  data-mobile-drawer
  aria-hidden="true"
  class="fixed inset-x-0 top-[60px] z-[calc(var(--z-header)-1)] hidden flex-col gap-1 border-b border-[color:var(--color-border)] bg-[color:var(--color-background)]/95 px-4 pb-6 pt-2 backdrop-blur-xl md:!hidden data-[open=true]:flex"
>
  {
    navLinks.map(({ label, href }) => (
      <a
        href={href}
        aria-current={isActive(path, href) ? "page" : undefined}
        data-mobile-link
        class="block rounded-md px-3 py-3 font-mono text-sm text-[color:var(--color-text-secondary)] active:scale-[0.98] active:bg-[color:var(--color-surface)] aria-[current=page]:text-[color:var(--color-accent)]"
      >
        → {label}
      </a>
    ))
  }
  <a
    href="mailto:hello@jcsoftdev.com"
    data-mobile-link
    class="mt-3 block rounded-md border border-[color:var(--color-accent-muted)] bg-[color:var(--color-accent-soft)] px-3 py-3 font-mono text-sm text-[color:var(--color-accent)] active:scale-[0.98]"
  >
    → Say hi · hello@jcsoftdev.com
  </a>
</div>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-toggle]",
  );
  const drawer = document.querySelector<HTMLElement>("[data-mobile-drawer]");
  const links =
    document.querySelectorAll<HTMLAnchorElement>("[data-mobile-link]");

  if (toggle && drawer) {
    const setOpen = (open: boolean) => {
      drawer.dataset.open = String(open);
      toggle.setAttribute("aria-expanded", String(open));
      drawer.setAttribute("aria-hidden", String(!open));
      const openIcon = toggle.querySelector("[data-menu-open]");
      const closeIcon = toggle.querySelector("[data-menu-close]");
      if (openIcon && closeIcon) {
        openIcon.classList.toggle("hidden", open);
        closeIcon.classList.toggle("hidden", !open);
      }
      document.body.style.overflow = open ? "hidden" : "";
    };
    toggle.addEventListener("click", () => {
      setOpen(drawer.dataset.open !== "true");
    });
    links.forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }
</script>
