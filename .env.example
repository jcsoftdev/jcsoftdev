# jcsoftdev — Environment Variable Reference
# Copy this file to .env and fill in real values.

# ── Docker Services Port Configuration (optional, avoid conflicts) ─────────────
# Set these BEFORE running `pnpm dev:services` if you have port conflicts.
# Defaults match docker-compose.yml — only override if needed.
# POSTGRES_PORT=5432          # Direct Postgres (migrations)
# PGBOUNCER_PORT=6432         # Postgres connection pool
# VALKEY_PORT=6379            # Redis-compatible cache
# MINIO_API_PORT=9000         # S3-compatible object storage API
# MINIO_CONSOLE_PORT=9001     # MinIO web console
# PLAUSIBLE_PORT=8000         # Analytics dashboard

NODE_ENV=development
DATABASE_URL=postgresql://jcsoftdev:devpassword@localhost:6432/jcsoftdev
DATABASE_DIRECT_URL=postgresql://jcsoftdev:devpassword@localhost:5432/jcsoftdev
VALKEY_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_MEDIA=jcsoftdev-media
PUBLIC_API_URL=http://localhost:5435
VITE_API_URL=http://localhost:5435
PORT=5435
CORS_ORIGINS=http://localhost:4321,http://localhost:5173
RESEND_API_KEY=re_placeholder_replace_me
RESEND_FROM_EMAIL=onboarding@resend.dev
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:5435
PLAUSIBLE_DOMAIN=localhost
PUBLIC_PLAUSIBLE_HOST=http://localhost:8000
